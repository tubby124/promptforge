{
  "manifest_version": 3,
  "name": "PromptForge",
  "version": "0.2.0",
  "description": "Profile-aware prompt optimizer for ChatGPT, Claude, Gemini, Perplexity, Grok. Sharpen (default) or Deep (Lyra-4D) mode. Streams via OpenRouter + Claude Haiku.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "https://openrouter.ai/*",
    "https://*.github.io/*",
    "https://raw.githubusercontent.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PromptForge — Optimize this prompt",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://grok.com/*",
        "https://x.com/i/grok*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "commands": {
    "open-optimizer": {
      "suggested_key": {
        "default": "Ctrl+Shift+O",
        "mac": "Command+Shift+O"
      },
      "description": "Open PromptForge optimizer"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["packs/default-pack.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
